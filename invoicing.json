        "sendTo": "={{ $('Poszukanie usera').item.json.Email }}",
        "subject": "Faktura od Momentum Konsulting",
        "message": "=<!DOCTYPE html>\n<html lang=\"pl\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Faktura od Momentum Konsulting</title>\n    <style>\n        /* Basic styles for better rendering */\n        body {\n            margin: 0;\n            padding: 0;\n            font-family: Arial, sans-serif;\n            background-color: #f4f7f6;\n        }\n        table {\n            border-collapse: collapse;\n        }\n        h1, h2, p {\n            margin: 0;\n        }\n    </style>\n</head>\n<body style=\"margin: 0; padding: 0; font-family: Arial, sans-serif; background-color: #f4f7f6;\">\n    <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\n        <tr>\n            <td style=\"padding: 20px 0;\">\n                <table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"600\" style=\"background-color: #ffffff; border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden;\">\n                    <!-- Header with Logo -->\n                    <tr>\n                        <td align=\"center\" style=\"padding: 40px 0; background-color: #005f73; color: #ffffff;\">\n                            <!-- Logo for Momentum Konsulting -->\n                            <img src=\"https://bcassetcdn.com/public/blog/wp-content/uploads/2019/07/18094631/consulting-summits.png\" alt=\"Logo Momentum Konsulting\" width=\"150\" style=\"display: block;\">\n                            <h1 style=\"margin: 20px 0 0 0; font-size: 28px;\">Faktura do opłacenia</h1>\n                        </td>\n                    </tr>\n                    <!-- Main Content -->\n                    <tr>\n                        <td style=\"padding: 40px 30px;\">\n                            <!-- Personalized Message -->\n                            <p style=\"font-size: 16px; line-height: 1.6em; margin: 0 0 25px 0; color: #333333;\">\n                                <!-- N8N Variable: Client Name -->\n                                Cześć {{ $('Poszukanie usera').item.json['Imię i Nazwisko'] }}\n                            </p>\n                            <p style=\"font-size: 16px; line-height: 1.6em; margin: 0 0 25px 0; color: #555555;\">\n                                W załączniku przesyłamy fakturę o numerze <strong><!-- N8N Variable: Invoice Number -->{{ $('Dodanie faktury do bazy').item.json.fields['Numer Faktury'] }}\n                            </p>\n                            <p style=\"font-size: 16px; line-height: 1.6em; margin: 0 0 25px 0; color: #555555;\">\n                                Szczegóły dotyczące płatności znajdziesz w załączonym pliku PDF.\n                            </p>\n                             <p style=\"font-size: 16px; line-height: 1.6em; margin: 0 0 25px 0; color: #555555;\">\n                                Dziękujemy za zaufanie i współpracę!\n                            </p>\n                             <p style=\"font-size: 16px; line-height: 1.6em; margin: 0; color: #555555;\">\n                                Pozdrawiamy,<br>\n                                Zespół Momentum Konsulting\n                            </p>\n                        </td>\n                    </tr>\n                    <!-- Footer -->\n                    <tr>\n                        <td align=\"center\" style=\"padding: 20px 30px; background-color: #eeeeee; color: #666666; font-size: 12px;\">\n                            <p style=\"margin: 0 0 5px 0;\">Otrzymałeś/aś tę wiadomość w związku z zamówionymi usługami.</p>\n                            <p style=\"margin: 0;\">Momentum Konsulting | ul. Wirtualna 1, 00-001 Warszawa</p>\n                        </td>\n                    </tr>\n                </table>\n            </td>\n        </tr>\n    </table>\n</body>\n</html>\n",
