              "name": "data",
              "type": "string",
              "value": "=<!DOCTYPE html>\n<html lang=\"pl\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>Faktura</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            color: #333;\n            margin: 0;\n            padding: 0;\n        }\n        .invoice-box {\n            max-width: 800px;\n            margin: auto;\n            padding: 30px;\n            border: 1px solid #eee;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.15);\n            font-size: 16px;\n            line-height: 24px;\n        }\n        .invoice-box table {\n            width: 100%;\n            line-height: inherit;\n            text-align: left;\n            border-collapse: collapse;\n        }\n        .invoice-box table td {\n            padding: 5px;\n            vertical-align: top;\n        }\n        .invoice-box table tr.top table td {\n            padding-bottom: 20px;\n        }\n        .invoice-box table tr.top table td.title {\n            font-size: 45px;\n            line-height: 45px;\n            color: #333;\n        }\n        .invoice-box table tr.information table td {\n            padding-bottom: 40px;\n        }\n        .invoice-box table tr.heading td {\n            background: #eee;\n            border-bottom: 1px solid #ddd;\n            font-weight: bold;\n        }\n        .invoice-box table tr.details td {\n            padding-bottom: 20px;\n        }\n        .invoice-box table tr.item td {\n            border-bottom: 1px solid #eee;\n        }\n        .invoice-box table tr.item.last td {\n            border-bottom: none;\n        }\n        .invoice-box table tr.total td:nth-child(2) {\n            border-top: 2px solid #eee;\n            font-weight: bold;\n        }\n        .text-right {\n            text-align: right;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"invoice-box\">\n        <table>\n            <tr class=\"top\">\n                <td colspan=\"4\">\n                    <table>\n                        <tr>\n                            <td class=\"title\">\n                                <!-- Logo Firmy -->\n                                <img src=\"https://bcassetcdn.com/public/blog/wp-content/uploads/2019/07/18094631/consulting-summits.png\" alt=\"Logo Momentum Konsulting\" style=\"width: 100%; max-width: 200px\">\n                            </td>\n                            <td class=\"text-right\">\n                                <!-- Numer Faktury -->\n                                <h1>FAKTURA</h1>\n                                <strong>Numer:</strong> <!-- N8N Variable: --> {{ $json.fields['Numer Faktury'] }}<br>\n                                <strong>Data wystawienia:</strong> <!-- N8N Variable: -->{{ $json.fields['Data Wystawienia'] }}<br>\n                                <strong>Data sprzedaży:</strong> <!-- N8N Variable: --> {{ $json.fields['Data Wystawienia'] }}\n                            </td>\n                        </tr>\n                    </table>\n                </td>\n            </tr>\n            <tr class=\"information\">\n                <td colspan=\"4\">\n                    <table>\n                        <tr>\n                            <td>\n                                <strong>Sprzedawca:</strong><br>\n                                Momentum Konsulting<br>\n                                ul. Wirtualna 1<br>\n                                00-001 Warszawa<br>\n                                NIP: 123-456-78-90\n                            </td>\n                            <td class=\"text-right\">\n                                <strong>Nabywca:</strong><br>\n                                <!-- N8N Variable: --> {{ $('Poszukanie usera').item.json['Imię i Nazwisko'] }}<br>\n                                <!-- N8N Variable: --> {{ $('Poszukanie usera').item.json['Nazwa Firmy'] }}<br>\n                                <!-- N8N Variable: --> {{ $('Poszukanie usera').item.json.Email }}\n                            </td>\n                        </tr>\n                    </table>\n                </td>\n            </tr>\n            <tr class=\"heading\">\n                <td>Opis usługi</td>\n                <td class=\"text-right\">Ilość</td>\n                <td class=\"text-right\">Cena netto</td>\n                <td class=\"text-right\">Wartość netto</td>\n            </tr>\n            <tr class=\"item\">\n                <!-- Tutaj można wstawić opis usługi, np. na podstawie sugerowanego pakietu -->\n                <td>Konsultacja i wdrożenie automatyzacji - Pakiet <!-- N8N Variable: --> {{ $('Poszukanie usera').item.json['Sugerowany Pakiet'] }}</td>\n                <td class=\"text-right\">1</td>\n                <td class=\"text-right\"><!-- N8N Variable: --> 100 PLN</td>\n                <td class=\"text-right\"><!-- N8N Variable: --> 100 PLN</td>\n            </tr>\n            <!-- Można dodać więcej pozycji w razie potrzeby -->\n            <tr class=\"total\">\n                <td colspan=\"3\" class=\"text-right\"><strong>Suma netto:</strong></td>\n                <td class=\"text-right\"><!-- N8N Variable: --> 100 PLN</td>\n            </tr>\n            <tr class=\"total\">\n                <td colspan=\"3\" class=\"text-right\"><strong>VAT (23%):</strong></td>\n                <!-- Należy obliczyć VAT w N8N: Kwota Brutto - Kwota Netto -->\n                <td class=\"text-right\"><!-- N8N Variable: --> 150  PLN</td>\n            </tr>\n            <tr class=\"total\">\n                <td colspan=\"3\" class=\"text-right\"><strong>Do zapłaty:</strong></td>\n                <td class=\"text-right\"><strong><!-- N8N Variable: --> 150  PLN</strong></td>\n            </tr>\n        </table>\n        <div style=\"margin-top: 40px;\">\n            <strong>Forma płatności:</strong> Przelew<br>\n            <strong>Termin płatności:</strong> 14 dni<br>\n            <strong>Numer konta:</strong> PL 12 3456 7890 1234 5678 9012 3456<br>\n            <br>\n            <p>Dziękujemy za skorzystanie z naszych usług!</p>\n        </div>\n    </div>\n</body>\n</html>\n"
            }
          ]
        },
        "options": {}
      },
